# =============================================================================
# ClamBot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values you need.
# ClamBot loads .env automatically via python-dotenv (override=False),
# so values here fill gaps — existing env vars always take priority.
#
# You only need keys for the providers you plan to use.
# Run `clambot onboard` after setting keys to auto-generate config.json.
# =============================================================================

# ---------------------
# ClamBot Configuration
# ---------------------

# Override path to config.json (default: ~/.clambot/config.json)
# CLAMBOT_CONFIG=/path/to/config.json

# ----------------------
# LLM Provider API Keys
# ----------------------
# These are scanned during `clambot onboard` and written into config.json.

# OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AI...

# ----------------------
# Ollama (Local LLM)
# ----------------------
# If Ollama is running, onboarding auto-detects it at this URL.

# OLLAMA_HOST=http://localhost:11434

# ----------------------
# Telegram Bot
# ----------------------
# Set this if you want the secret resolver to find the token from env.
# The primary config path is channels.telegram.token in config.json.

# TELEGRAM_BOT_TOKEN=123456:ABC-...

# ----------------------
# Transcribe Tool (Groq Whisper)
# ----------------------
# Required only if you use the `transcribe` tool. Uses the same GROQ_API_KEY
# above — no separate variable needed.
